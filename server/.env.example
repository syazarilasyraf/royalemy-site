# Backend Environment Variables
# Copy this file to .env and fill in your values

# Clash Royale API Token (required)
# Get your token from: https://developer.clashroyale.com/
CR_API_TOKEN=your_token_here

# Server Port (default: 3001)
PORT=3001

# Frontend URL for CORS (required for separate frontend)
# Set this to your Netlify deployment URL, e.g.:
# FRONTEND_URL=https://your-site.netlify.app
#
# For local development with Vite dev server:
FRONTEND_URL=http://localhost:5173

# Optional: allow additional origins (comma-separated)
# Useful for preview deployments
# CORS_ORIGINS=https://preview-1.netlify.app,https://preview-2.netlify.app
