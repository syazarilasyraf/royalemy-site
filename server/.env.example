# Backend Environment Variables
# Copy this file to .env and fill in your values

# Clash Royale API Token (required)
# Get your token from: https://developer.clashroyale.com/
CR_API_TOKEN=your_token_here

# Server Port (default: 3001)
PORT=3001

# Frontend URL for CORS (required for separate frontend)
# Set this to your Netlify deployment URL, e.g.:
# FRONTEND_URL=https://your-site.netlify.app
#
# For local development with Vite dev server:
FRONTEND_URL=http://localhost:5173

# Optional: allow additional origins (comma-separated)
# Useful for preview deployments
# CORS_ORIGINS=https://preview-1.netlify.app,https://preview-2.netlify.app

# Roadmap Admin Key (required for admin actions)
# Generate a random string, e.g.:
# ROADMAP_ADMIN_KEY=b80adce29ae0f21db3883c4e1642c12943237a7d74c67c71

# VAPID Keys for Push Notifications (required for tournament notifications)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BEA0HRFKiWyh0_PWXjqLEBDY_L3jOSTNRNRpVhFx-5mfYyGvBf6Quu0c8t-Oyn0K0bMaknRqWioTsg-omNPgVoA
VAPID_PRIVATE_KEY=h48ok99uqoCJ_3hm1oXVq9-x1HUdAg3PbOmtYb2aFW0
VAPID_SUBJECT=mailto:admin@royalemy.gg
