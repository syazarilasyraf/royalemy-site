# Frontend Environment Variables
# Copy this file to .env and fill in values for local development

# Backend API URL
# - For local dev with Vite proxy: leave empty or comment out (uses /api)
# - For production (Netlify): set to your backend URL
#   Example: VITE_API_URL=https://your-backend.f.jrnm.app/api
VITE_API_URL=

# Public site URL (used for shareable links and Open Graph previews)
# - For local dev: leave empty or comment out (falls back to backend share endpoint)
# - For production (Netlify custom domain): set to your domain
#   Example: VITE_SITE_URL=https://royalemy.com
VITE_SITE_URL=
