# Frontend Environment Variables
# Copy this file to .env and fill in values for local development

# Backend API URL
# - For local dev with Vite proxy: leave empty or comment out (uses /api)
# - For production (Vercel): set to your ngrok or backend URL
#   Example: VITE_API_URL=https://your-app.ngrok-free.app/api
VITE_API_URL=
